<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Customize your theme here -->
        <item name="colorPrimary">@color/background_color</item>
        <item name="colorPrimaryDark">@color/text_primary</item>
        <item name="colorAccent">@color/success_color</item>
    </style>

    <!-- TV应用主题 -->
    <style name="AppTheme.TV" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/tv_background</item>
        <item name="android:textColor">@color/tv_text_primary</item>
    </style>

    <!-- 频道列表项样式 -->
    <style name="ChannelItemText">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:padding">12dp</item>
    </style>

    <!-- 分组标题样式 -->
    <style name="GroupItemText">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- 设置项样式 -->
    <style name="SettingItem">
        <item name="android:padding">16dp</item>
        <item name="android:background">?android:attr/selectableItemBackground</item>
    </style>

    <!-- 播放器控制按钮样式 -->
    <style name="PlayerControlButton">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:background">@drawable/selectable_item_background_borderless</item>
        <item name="android:scaleType">centerInside</item>
    </style>

    <!-- 频道信息文本样式 -->
    <style name="ChannelInfoText">
        <item name="android:textSize">20sp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:shadowColor">@color/text_primary</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
    </style>

    <!-- 授权对话框样式 -->
    <style name="AuthDialogStyle" parent="Theme.AppCompat.Dialog.Alert">
        <item name="android:windowBackground">@color/auth_dialog_background</item>
        <item name="android:textColorPrimary">@color/white</item>
    </style>
</resources>