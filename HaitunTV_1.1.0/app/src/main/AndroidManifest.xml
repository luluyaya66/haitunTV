<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-sdk android:minSdkVersion="19" android:targetSdkVersion="34" tools:overrideLibrary="androidx.leanback.widget,androidx.constraintlayout.widget,androidx.leanback.grid,androidx.leanback,androidx.appcompat.resources,androidx.appcompat,androidx.recyclerview,androidx.core.ktx,androidx.core,androidx.core.viewtree"
        tools:ignore="GradleOverrides" />

    <!-- 基础权限 -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.REQUEST_COMPANION_START_FOREGROUND_SERVICES_FROM_BACKGROUND" />
    <uses-permission android:name="android.permission.START_ACTIVITIES_FROM_BACKGROUND" />
    <!-- 添加写入外部存储权限，用于首次运行标记 -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    
    <!-- TV应用必要声明 -->
    <uses-feature android:name="android.software.leanback"
        android:required="true" />
    <uses-feature android:name="android.hardware.touchscreen"
        android:required="false" />
        
    <!-- 应用特性声明 -->
    <uses-feature android:name="android.hardware.type.television"
        android:required="true" />
    <uses-feature android:name="android.hardware.input.remote" />
    <uses-feature android:name="android.hardware.opengles" />
    <uses-feature android:name="android.hardware.video.decoder" />

    <!-- 声明需要查询的应用包，用于解决Android 11及以上版本的包可见性限制 -->
    <queries>
        <!-- 查询能够处理APK安装的应用 -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:mimeType="application/vnd.android.package-archive" />
        </intent>
        
        <!-- 查询能够处理网络连接状态变更的应用 -->
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <data android:scheme="https" />
        </intent>
    </queries>

    <application
        android:name=".ui.MyTVApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme.TV"
        android:hardwareAccelerated="true"
        android:banner="@drawable/mydiy_banner"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config"
        tools:ignore="UnusedAttribute">

        <!-- 主入口Activity -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:screenOrientation="landscape"
            android:banner="@drawable/mydiy_banner"
            tools:ignore="UnusedAttribute">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <!-- 添加标准LAUNCHER意图过滤器，确保在普通Android设备上也能显示 -->
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 启动完成接收器 -->
        <receiver
            android:name=".services.BootReceiver"
            android:exported="true">
            <intent-filter android:priority="1000">
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <!-- 网络状态变化接收器 -->
        <receiver
            android:name=".network.NetworkStateReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.net.conn.CONNECTIVITY_CHANGE" />
            </intent-filter>
            <intent-filter>
                <action android:name="network_retry_action" />
            </intent-filter>
        </receiver>

        <!-- 数据同步服务 -->
        <service
            android:name=".services.DataSyncService"
            android:exported="false" />

        <!-- 播放服务 -->
        <service
            android:name=".services.PlaybackService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />
        
        <!-- AI语音服务 -->
        <service
            android:name="com.peasun.aispeech.aiopen.AIOpenService"
            android:foregroundServiceType="shortService"
            android:exported="true">
            <intent-filter>
                <action android:name="com.peasun.aispeech.action.live" />
            </intent-filter>
        </service>
        
        <!-- AI语音接收器 -->
        <receiver
            android:name="com.peasun.aispeech.aiopen.AIOpenReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.peasun.aispeech.action.app.register.require" />
            </intent-filter>
        </receiver>

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

    </application>

</manifest>