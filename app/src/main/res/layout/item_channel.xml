<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:background="@drawable/channel_item_background"
    android:paddingLeft="@dimen/menu_item_padding_horizontal"
    android:paddingRight="@dimen/menu_item_padding_horizontal"
    android:paddingTop="@dimen/menu_item_padding_vertical"
    android:paddingBottom="@dimen/menu_item_padding_vertical"
    android:focusable="true"
    android:clickable="true">

    <ImageView
        android:id="@+id/channel_logo"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:scaleType="fitCenter"
        app:srcCompat="@mipmap/ic_launcher_round"
        android:layout_marginEnd="12dp"
        android:contentDescription="@string/channel_info" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_gravity="center_vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/channel_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:textSize="@dimen/menu_channel_text_size" />

            <ImageView
                android:id="@+id/favorite_indicator"
                android:layout_width="16dp"
                android:layout_height="16dp"
                app:srcCompat="@drawable/ic_favorite_selector"
                android:layout_gravity="center_vertical"
                android:contentDescription="@string/favorite"
                android:layout_marginStart="4dp"
                android:visibility="visible" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/epg_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/menu_epg_text_size"
                android:maxLines="1"
                android:ellipsize="end"
                android:visibility="gone" />

            <ImageView
                android:id="@+id/epg_arrow_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                app:srcCompat="@drawable/ic_keyboard_arrow_right"
                android:layout_gravity="center_vertical"
                android:contentDescription="EPG"
                android:layout_marginStart="4dp"
                android:visibility="visible" />

        </LinearLayout>

    </LinearLayout>

</LinearLayout>